.1-3.2 5.7.3.4h.7l12-2.6 6.4-1.1 7.6-1.3 3.5 1.6.4 1.6-1.4 3.4-8.2 2-9.6 2-14.3 3.3-.2.1.2.3 6.4.6 2.8.2h6.8l12.6 1 3.3 2 1.9 2.7-.3 2-5.1 2.6-6.8-1.6-16-3.8-5.4-1.3h-.8v.4l4.6 4.5 8.3 7.5L89 80.1l.5 2.4-1.3 2-1.4-.2-9.2-7-3.6-3-8-6.8h-.5v.7l1.8 2.7 9.8 14.7.5 4.5-.7 1.4-2.6 1-2.7-.6-5.8-8-6-9-4.7-8.2-.5.4-2.9 30.2-1.3 1.5-3 1.2-2.5-2-1.4-3 1.4-6.2 1.6-8 1.3-6.4 1.2-7.9.7-2.6v-.2H49L43 72l-9 12.3-7.2 7.6-1.7.7-3-1.5.3-2.8L24 86l10-12.8 6-7.9 4-4.6-.1-.5h-.3L17.2 77.4l-4.7.6-2-2 .2-3 1-1 8-5.5Z"></path></svg></div></div></div></div><div class="inline-flex items-center gap-1 min-w-0" style="opacity: 1;"><span class="truncate font-base">Deliberated repositioning strategies for misplaced dashboard text object</span><span class="inline-flex -rotate-90 shrink-0 opacity-0 transition-opacity duration-200 group-hover/status:opacity-100 group-focus-visible/status:opacity-100"><div style="width: 12px; height: 12px; display: flex; align-items: center; justify-content: center;"><svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="flex-shrink: 0;"><path d="M14.128 7.165a.502.502 0 0 1 .744.67l-4.5 5-.078.07a.5.5 0 0 1-.666-.07l-4.5-5-.06-.082a.501.501 0 0 1 .729-.656l.075.068L10 11.752z"></path></svg></div></span></div></button></div><span class="sr-only" role="status" aria-live="polite">Deliberated repositioning strategies for misplaced dashboard text object</span><div class="grid transition-[grid-template-rows] duration-300 ease-out" style="grid-template-rows: 0fr;"><div class="overflow-hidden min-w-0"></div></div></div></div></div><div class="row-start-2 col-start-1 relative grid grid-rows-[auto_auto] isolate min-w-0"><div class="row-start-1 col-start-1 relative z-[2] min-w-0"><div><div><div class="standard-markdown grid-cols-1 grid [&amp;_&gt;_*]:min-w-0 gap-3 standard-markdown"><p class="font-claude-response-body break-words whitespace-normal">Tableau dashboards use a "tiled" layout by default, which means dragging an item only works if you drop it in exactly the right spot to create a new row — that's likely why it landed awkwardly last time. Given you've had trouble with precise dragging before, switching the title to "Floating" is the more forgiving fix, since floating objects can go anywhere without needing to hit an exact drop zone.</p>
<p class="font-claude-response-body break-words whitespace-normal">Here's how:</p>
<p class="font-claude-response-body break-words whitespace-normal">Click directly on the title text box once to select it — you'll see a thin gray border appear around it.</p>
<p class="font-claude-response-body break-words whitespace-normal">Look at the bottom-left of your screen, under the "Objects" list, where you'll see two buttons: <strong>Tiled</strong> and <strong>Floating</strong>. With the title still selected, click <strong>Floating</strong>.</p>
<p class="font-claude-response-body break-words whitespace-normal">The text box will pop out of the grid layout. Now click and drag it (from the middle of the box, not the edge) up to the top of the dashboard canvas — since it's floating, it'll move freely without disturbing your four charts.</p>
<p class="font-claude-response-body break-words whitespace-normal">Once it's roughly in place, drag the small square handles on its corners/edges to stretch it so it spans the full width of the dashboard, sitting just above all four chart panels.</p>
<p class="font-claude-response-body break-words whitespace-normal">If floating feels harder to control instead of easier, the alternative is to drag it back to <strong>Tiled</strong> and try dropping it again, but this time aim specifically for the thin strip right above your top-left chart's title bar — Tableau will show a blue horizontal highlight bar across the full width when you're in the right spot; that's your cue to release.</p>
<p class="font-claude-response-body break-words whitespace-normal">Send a screenshot once you've tried either approach.</p></div></div></div></div></div></div></div></div></div></div><div data-message-action-bar="" class="flex justify-start opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 pointer-coarse:opacity-100 transition"><div class="text-text-300"><div role="toolbar" aria-label="Message actions" class="text-text-300 flex select-none items-stretch justify-between"><button type="button" data-cds="Button" class="cds-reset group/btn relative isolate inline-flex shrink-0 items-center justify-center gap-1.5 whitespace-nowrap select-none cursor-[var(--cds-cursor-interactive)] aria-disabled:cursor-default data-[disabled]:cursor-default border-0 outline-none rounded h-control font-sans text-body font-medium [&amp;:disabled:not([aria-busy])]:opacity-50 disabled:pointer-events-none transition-shadow duration-fast focus-visible:shadow-focus text-primary aria-pressed:text-accent aspect-square w-control px-0 !text-muted hover:!text-primary" aria-label="Copy" data-testid="action-bar-copy" id="base-ui-_r_18c_" tabindex="0"><span aria-hidden="true" class="absolute -z-[1] rounded-[inherit] transition-colors duration-fast group-focus-visible/btn:shadow-[inset_0_0_0_1px_var(--cds-page-bg)] bg-transparent group-hover/btn:bg-fill-ghost-hover group-aria-expanded/btn:bg-fill-ghost-hover inset-0 group-aria-pressed/btn:bg-accent group-hover/btn:group-aria-pressed/btn:bg-accent cds-btn-squish "></span><span class="inline-flex items-center gap-1 "><span class="relative"><span data-cds="Icon" class="transition-all opacity-100 scale-100" aria-hidden="true" style="font-family: var(--font-anthropicons, Anthropicons-Variable); font-feature-settings: &quot;liga&quot; 0; font-optical-sizing: auto; font-style: normal; font-variation-settings: normal; line-height: 1; width: 1em; height: 1em; display: flex; align-items: center; justify-content: center; flex-shrink: 0; user-select: 